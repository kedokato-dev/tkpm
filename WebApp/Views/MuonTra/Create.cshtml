@model MuonTra

@{
    ViewData["Title"] = "Tạo phiếu mượn sách";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-md-8 offset-md-2">
            <h2><i class="bi bi-plus-circle"></i> Tạo phiếu mượn sách</h2>
            <hr />

            <form method="get" id="formPhieu">
                <div class="mb-3">
                    <label for="nguoiMuon" class="form-label">Người mượn <span class="text-danger">*</span></label>
                    <input type="text" id="nguoiMuon" class="form-control" placeholder="Nhập tên người mượn" required />
                </div>

                <div class="mb-3">
                    <label for="sachMuon" class="form-label">Chọn sách <span class="text-danger">*</span></label>
                    <input type="text" id="sachMuon" class="form-control" placeholder="Nhập tên sách" required />
                </div>

                <div class="mb-3">
                    <label for="hanTra" class="form-label">Hạn trả <span class="text-danger">*</span></label>
                    <input type="datetime-local" id="hanTra" class="form-control" required />
                </div>

                <div class="mb-3">
                    <label for="ghiChu" class="form-label">Ghi chú</label>
                    <textarea id="ghiChu" class="form-control" rows="3"
                              placeholder="Nhập ghi chú (tùy chọn)"></textarea>
                </div>

                <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                    <a href="/" class="btn btn-secondary">Hủy</a>
                    <button type="button" class="btn btn-primary" onclick="inPhieu()">Tạo phiếu mượn</button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
    function inPhieu() {
        // Lấy dữ liệu từ form
        const nguoiMuon = document.getElementById('nguoiMuon').value.trim();
        const sachMuon = document.getElementById('sachMuon').value.trim();
        const hanTra = document.getElementById('hanTra').value.trim();
        const ghiChu = document.getElementById('ghiChu').value.trim();

        // Kiểm tra dữ liệu bắt buộc
        if (!nguoiMuon || !sachMuon || !hanTra) {
            alert('❌ Vui lòng điền đầy đủ thông tin bắt buộc!');
            return;
        }

        // Gửi dữ liệu đến server
        fetch('/api/muontra/save', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
            },
            body: JSON.stringify({
                nguoiMuon: nguoiMuon,
                sachMuon: sachMuon,
                hanTra: hanTra,
                ghiChu: ghiChu
            })
        })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    // Hiển thị chi tiết phiếu
                    alert('v ' + data.message + '\n\n' +
                        'Chi tiết phiếu:\n' +
                        '- ID: ' + data.data.id + '\n' +
                        '- Người mượn: ' + data.data.nguoiMuon + '\n' +
                        '- Sách: ' + data.data.sachMuon + '\n' +
                        '- Hạn trả: ' + data.data.hanTra + '\n' +
                        '- Ghi chú: ' + (data.data.ghiChu || '(Không có)') + '\n' +
                        '- Ngày tạo: ' + new Date(data.data.ngayTao).toLocaleString('vi-VN'));

                    // Reset form
                    document.getElementById('formPhieu').reset();

                    // Quay về trang chủ sau 2 giây
                    setTimeout(function () {
                        window.location.href = '/';
                    }, 2000);
                } else {
                    alert('❌ Lỗi: ' + data.message);
                }
            })
            .catch(error => {
                console.error('Error:', error);
                alert('❌ Có lỗi xảy ra: ' + error);
            });
    }
</script>