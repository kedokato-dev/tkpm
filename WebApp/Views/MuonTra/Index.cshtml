@model IEnumerable<WebApp.Models.MuonTra>
@{
    ViewData["Title"] = "Quản lý Mượn trả";
}

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle-fill me-2"></i>@TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="fw-bold mb-1">Quản lý Mượn trả</h2>
        <p class="text-muted mb-0">Tổng cộng <strong>@Model.Count()</strong> phiếu mượn</p>
    </div>
    <a asp-action="Create" class="btn btn-primary btn-lg shadow-sm">
        <i class="bi bi-plus-lg me-1"></i> Tạo phiếu mượn
    </a>
</div>

<div class="card shadow-sm border-0">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th style="width: 60px">#</th>
                    <th>Người mượn</th>
                    <th>Sách</th>
                    <th>Mã cá biệt</th>
                    <th class="text-center">Ngày tạo</th>
                    <th class="text-center">Hạn trả</th>
                    <th class="text-center">Ngày trả</th>
                    <th class="text-center">Tiền phạt</th>
                    <th class="text-center">Trạng thái</th>
                    <th class="text-end" style="width: 200px">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="10" class="text-center py-5 text-muted">
                            <i class="bi bi-inbox fs-1 d-block mb-2"></i>
                            Không có phiếu mượn nào
                        </td>
                    </tr>
                }
                @{ var stt = 0; }
                @foreach (var item in Model)
                {
                    stt++;
                    <tr>
                        <td class="text-muted">@stt</td>
                        <td>@item.NguoiDung?.HoTen</td>
                        <td>@item.DangKyCaBiet?.Sach?.TieuDe</td>
                        <td><code>@item.DangKyCaBiet?.MaCaBiet</code></td>
                        <td class="text-center">@item.NgayTao.ToString("dd/MM/yyyy")</td>
                        <td class="text-center">@item.HanTra.ToString("dd/MM/yyyy")</td>
                        <td class="text-center">
                            @if (item.NgayTra.HasValue)
                            {
                                @item.NgayTra.Value.ToString("dd/MM/yyyy")
                            }
                            else
                            {
                                <span class="text-muted">-</span>
                            }
                        </td>
                        <td class="text-center">
                            @if (item.TienPhat > 0)
                            {
                                <span class="text-danger fw-semibold">@item.TienPhat?.ToString("N0") VND</span>
                            }
                            else
                            {
                                <span class="text-muted">0</span>
                            }
                        </td>
                        <td class="text-center">
                            @if (item.TrangThai == "Đang mượn")
                            {
                                <span class="badge bg-warning-subtle text-warning-emphasis">@item.TrangThai</span>
                            }
                            else if (item.TrangThai == "Đã trả")
                            {
                                <span class="badge bg-success-subtle text-success-emphasis">@item.TrangThai</span>
                            }
                            else if (item.TrangThai == "Quá hạn")
                            {
                                <span class="badge bg-danger-subtle text-danger-emphasis">@item.TrangThai</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary-subtle text-secondary-emphasis">@item.TrangThai</span>
                            }
                        </td>
                        <td class="text-end">
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info" title="Chi tiết">
                                <i class="bi bi-eye"></i>
                            </a>
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-warning" title="Sửa">
                                <i class="bi bi-pencil"></i>
                            </a>
                            @if (item.TrangThai == "Đang mượn")
                            {
                                <form asp-action="TraSach" asp-route-id="@item.Id" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-outline-success" title="Trả sách"
                                            onclick="return confirm('Xác nhận trả sách?')">
                                        <i class="bi bi-check-lg"></i>
                                    </button>
                                </form>
                            }
                            <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-outline-danger" title="Xóa"
                                        onclick="return confirm('Bạn có chắc chắn muốn xóa phiếu mượn này?')">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
