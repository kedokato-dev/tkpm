@model Library.Core.Entities.Sach
@{
    ViewData["Title"] = Model.TieuDe;
}

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="d-flex align-items-center mb-4">
            <a asp-action="Index" class="btn btn-outline-secondary me-3">
                <i class="bi bi-arrow-left"></i>
            </a>
            <h2 class="fw-bold mb-0">Chi tiết sách</h2>
        </div>

        <div class="card shadow-sm border-0">
            <div class="card-body p-4">
                <div class="row">
                    <div class="col-md-4 text-center mb-3">
                        @if (!string.IsNullOrEmpty(Model.HinhAnh))
                        {
                            <img src="@Model.HinhAnh" alt="@Model.TieuDe" class="img-fluid rounded shadow-sm"
                                 style="max-height: 300px; object-fit: cover;" />
                        }
                        else
                        {
                            <div class="bg-light rounded d-flex align-items-center justify-content-center"
                                 style="height: 300px;">
                                <i class="bi bi-book fs-1 text-muted"></i>
                            </div>
                        }
                    </div>
                    <div class="col-md-8">
                        <h3 class="fw-bold mb-2">@Model.TieuDe</h3>
                        <span class="badge @(Model.TrangThai == "Hoạt động" ? "bg-success-subtle text-success-emphasis" : "bg-secondary-subtle text-secondary-emphasis") mb-3">
                            @Model.TrangThai
                        </span>

                        <table class="table table-borderless mt-3">
                            <tr>
                                <td class="text-muted fw-semibold" style="width: 160px">ISBN</td>
                                <td><code>@Model.MaIsbn</code></td>
                            </tr>
                            <tr>
                                <td class="text-muted fw-semibold">Thể loại</td>
                                <td>@Model.Theloai?.Ten</td>
                            </tr>
                            <tr>
                                <td class="text-muted fw-semibold">Nhà xuất bản</td>
                                <td>@Model.Nhaxuatban?.Ten</td>
                            </tr>
                            @if (Model.SachTacgia.Any())
                            {
                                <tr>
                                    <td class="text-muted fw-semibold">Tác giả</td>
                                    <td>@string.Join(", ", Model.SachTacgia.OrderBy(st => st.ThuTu).Select(st => st.TacGia.Ten))</td>
                                </tr>
                            }
                            <tr>
                                <td class="text-muted fw-semibold">Năm xuất bản</td>
                                <td>@Model.NamXuatBan</td>
                            </tr>
                            <tr>
                                <td class="text-muted fw-semibold">Phiên bản</td>
                                <td>@Model.PhienBan</td>
                            </tr>
                            <tr>
                                <td class="text-muted fw-semibold">Ngôn ngữ</td>
                                <td>@Model.NgonNgu</td>
                            </tr>
                            <tr>
                                <td class="text-muted fw-semibold">Số trang</td>
                                <td>@Model.SoTrang</td>
                            </tr>
                            <tr>
                                <td class="text-muted fw-semibold">Giá tiền</td>
                                <td>@(Model.GiaTien?.ToString("N0")) VNĐ</td>
                            </tr>
                        </table>
                    </div>
                </div>

                <hr />

                <div class="row g-3 mb-4">
                    <div class="col-md-4">
                        <div class="bg-primary-subtle rounded p-3 text-center">
                            <div class="fs-4 fw-bold text-primary">@(Model.SoLuongNhap ?? 0)</div>
                            <small class="text-muted">Số lượng nhập</small>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="bg-success-subtle rounded p-3 text-center">
                            <div class="fs-4 fw-bold text-success">@(Model.SoLuongTon ?? 0)</div>
                            <small class="text-muted">Số lượng tồn</small>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="bg-warning-subtle rounded p-3 text-center">
                            <div class="fs-4 fw-bold text-warning">@(Model.SoLuongChoMuon ?? 0)</div>
                            <small class="text-muted">Đang cho mượn</small>
                        </div>
                    </div>
                </div>

                @if (!string.IsNullOrEmpty(Model.MoTa))
                {
                    <h5 class="fw-semibold">Mô tả</h5>
                    <p class="text-muted">@Model.MoTa</p>
                }

                <hr />
                <div class="d-flex justify-content-end gap-2">
                    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning px-4">
                        <i class="bi bi-pencil me-1"></i> Chỉnh sửa
                    </a>
                    <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-outline-danger px-4">
                        <i class="bi bi-trash me-1"></i> Xóa
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
